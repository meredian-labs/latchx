{
  "name": "@meredian-labs/latchx",
  "version": "0.1.3",
  "description": "A safer npx replacement that audits npm packages before execution.",
  "type": "module",
  "bin": {
    "latchx": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "npm run build -w latch-core && tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "dev": "tsx src/index.ts"
  },
  "files": [
    "dist",
    "README.md",
    "docs",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/meredian-labs/latchx.git",
    "directory": "packages/latchx"
  },
  "keywords": [
    "npx",
    "npm",
    "security",
    "supply-chain",
    "package-audit",
    "cli",
    "policy"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "latch-core": "^0.1.3",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9"
  }
}
